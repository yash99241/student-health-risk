```gitignore
# Virtual Environment
venv/
.venv/
env/

# Python cache
__pycache__/
*.py[cod]
*.pyo

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# VS Code
.vscode/

# PyCharm
.idea/

# OS files
.DS_Store
Thumbs.db

# Environment variables
.env

# Logs
*.log

# Build files
build/
dist/
*.egg-info/

# Cache
.pytest_cache/
.mypy_cache/

# Streamlit cache
.streamlit/cache/

# Large model files (Uncomment if you DON'T want to upload them)
# *.pkl
# *.joblib
```
